# PayNow Credentials Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file to version control!

# PayNow Integration Credentials
# Get these from: https://www.paynow.co.zw/merchant/management
PAYNOW_INTEGRATION_ID=your_integration_id_here
PAYNOW_INTEGRATION_KEY=your_integration_key_here

# Server Configuration
NODE_ENV=development
PORT=3000

# Database (Optional - for production)
DATABASE_URL=mongodb://localhost:27017/techhub

# Email Service (Optional - for order confirmations)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your_email_api_key_here

# PayNow API Endpoints
PAYNOW_API_URL=https://www.paynow.co.zw/api/initiate-transaction
PAYNOW_POLL_URL=https://www.paynow.co.zw/api/poll-transaction

# Application URLs
APP_URL=http://localhost:3000
RETURN_URL=http://localhost:3000/payment-return
RESULT_URL=http://localhost:3000/payment-result
