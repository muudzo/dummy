{
  "name": "techhub-zimbabwe",
  "version": "1.0.0",
  "description": "Dummy e-commerce website with PayNow Zimbabwe payment integration",
  "main": "index.html",
  "scripts": {
    "start": "python3 -m http.server 8000 || python -m SimpleHTTPServer 8000",
    "start:node": "npx http-server -p 8000",
    "start:server": "node paynow-server.js",
    "start:dev": "node paynow-server.js",
    "test": "echo \"Run tests in TESTING.md\"",
    "dev": "npx live-server"
  },
  "keywords": [
    "paynow",
    "zimbabwe",
    "payment",
    "e-commerce",
    "demo",
    "integration"
  ],
  "author": "TechHub Zimbabwe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muudzo/dummy.git"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "live-server": "^1.2.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "paynow": "^2.2.2"
  },
  "optionalDependencies": {
    "mongoose": "^7.0.0",
    "nodemailer": "^8.0.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository-info": {
    "description": "Complete dummy website for PayNow Zimbabwe integration testing",
    "features": [
      "Product catalog",
      "Shopping cart",
      "PayNow payment integration",
      "Mobile responsive design",
      "Order tracking",
      "Payment history"
    ],
    "files": {
      "index.html": "Main website HTML",
      "style.css": "Styling and responsive design",
      "script.js": "Shopping cart and payment logic",
      "paynow-integration-example.js": "Real API integration example",
      "README.md": "Complete documentation",
      "QUICKSTART.md": "Quick start guide",
      "TESTING.md": "Testing guide",
      "start-server.sh": "Server startup script"
    }
  }
}
